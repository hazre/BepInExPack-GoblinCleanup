<Project Sdk="Cake.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RunWorkingDirectory>$(MSBuildProjectDirectory)/..</RunWorkingDirectory>
    <PackageVersion>5.4.230501</PackageVersion>
    <UnityVersion>2023.2.22f1</UnityVersion>
    <UnityHubDir>C:\Program Files\Unity\Hub\Editor</UnityHubDir>
    <GameDir>C:\Program Files (x86)\Steam\steamapps\common\Goblin Cleanup</GameDir>
    <!-- Package version: Major.Minor.BepInExPatch(2d)BepInExBuild(2d)PackPatch(2d).
         e.g. BepInEx 5.4.23.5 → remove dot → 5.4.2305 + pack patch 01 = 5.4.230501.
         Knope manages the pack patch suffix (last 2 digits). -->
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Mono.Cecil" Version="0.11.6" />
  </ItemGroup>
</Project>
